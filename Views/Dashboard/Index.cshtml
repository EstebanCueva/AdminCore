@{
    ViewData["Title"] = "Dashboard Admin";
}

<h1>Panel Administrativo</h1>

<p>Este panel permite administrar la configuración base del sistema de gestión de gastos empresariales.</p>

<hr />

<h3>Resumen</h3>

<p>Total empresas: @ViewBag.TotalEmpresas</p>
<p>Total áreas: @ViewBag.TotalAreas</p>
