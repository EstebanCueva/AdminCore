@model AdminCore.Models.Proveedor

<h1>Editar proveedor</h1>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <label>Empresa</label>
    <select asp-for="EmpresaId" asp-items="ViewBag.EmpresaId" class="form-control">
        <option value="">Seleccione una empresa</option>
    </select>
    <span asp-validation-for="EmpresaId" class="text-danger"></span>

    <label>Nombre</label>
    <input asp-for="Nombre" class="form-control" />
    <span asp-validation-for="Nombre" class="text-danger"></span>

    <label>RUC</label>
    <input asp-for="Ruc" class="form-control" />
    <span asp-validation-for="Ruc" class="text-danger"></span>

    <label>Correo</label>
    <input asp-for="Correo" class="form-control" />
    <span asp-validation-for="Correo" class="text-danger"></span>

    <label>Teléfono</label>
    <input asp-for="Telefono" class="form-control" />

    <label>Tipo de proveedor</label>
    <input asp-for="TipoProveedor" class="form-control" />

    <br />

    <label>
        <input asp-for="Activo" />
        Activo
    </label>

    <br />
    <br />

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index">Volver</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}